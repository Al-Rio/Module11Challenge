@page
@model ProductsModel

@{
    // C# code block where server-side code runs
    ViewData["Title"] = "Inventory"; // Sets the page title 
}

<!--Page Title--> 
<h1>@ViewData["Title"]</h1>

<table class="table">
   <thead><tr>
      <th>Product Name</th>
      <th>Product Price</th>
      <th>Product Description</th>
      <th>Product Stock Quantity</th>
   </tr></thead>
   <tbody>

 <!-- Loops through products and adds each row to the table -->
      @foreach (var product in Model.Products)
      {
         <tr>
            <td>@product.Name</td>
            <td>@product.Price.ToString("C")</td>
            <td>@product.Description</td>
            <td>@product.StockQuantity</td>
         </tr>
      }
   </tbody>
</table>
